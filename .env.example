# ============================================================
# DEADMANSWITCH AI – Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Deployer / Owner wallet private key (no 0x prefix needed)
PRIVATE_KEY=your_wallet_private_key_here

# Automation wallet private key – separate from owner for security
# This wallet will be registered as the Chainlink CRE executor
AUTOMATION_PRIVATE_KEY=your_automation_wallet_private_key_here

# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Block explorer API keys (optional – only needed for contract verification)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Chainlink Automation Registry address on Base Sepolia
# v2.1 registry: 0xE16Df59B887e3Caa439E0b29B42bA2e7976FD8b2
CHAINLINK_REGISTRY_BASE_SEPOLIA=0xE16Df59B887e3Caa439E0b29B42bA2e7976FD8b2
